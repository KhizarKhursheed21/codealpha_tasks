#include <iostream>
#include <fstream>
#include <string>

using namespace std;

class User
{
private:
    string userName;
    string password;

public:

    bool validateUsername(const string& userName)
    {
        if(userName.empty())
        {
            cout << "Username cannot be empty.\n";
            return false;
        }

        if(userName.length() < 5)
        {
            cout << "Username must contain at least 5 characters.\n";
            return false;
        }

        return true;
    }

    bool validatePassword(const string& password)
    {
        if(password.empty())
        {
            cout << "Password cannot be empty.\n";
            return false;
        }

        if(password.length() < 8)
        {
            cout << "Password must contain at least 8 characters.\n";
            return false;
        }

        return true;
    }

    void registerUser()
    {
        cout << "\nEnter Username: ";
        cin >> userName;

        cout << "Enter Password: ";
        cin >> password;

        if(!validateUsername(userName))
            return;

        if(!validatePassword(password))
            return;

        string fileName = userName + ".txt";

        ifstream checkFile(fileName);

        if(checkFile)
        {
            cout << "Error: username already exists.\n";
            checkFile.close();
            return;
        }

        checkFile.close();

        ofstream outFile(fileName);

        if(!outFile)
        {
            cout << "Error creating user file.\n";
            return;
        }

        outFile << userName << endl;
        outFile << password << endl;

        outFile.close();

        cout << "Registration Successful!\n";
    }

    void loginUser()
    {
        string enterUserName;
        string enterPassword;

        cout << "\nEnter Username: ";
        cin >> enterUserName;

        cout << "Enter Password: ";
        cin >> enterPassword;

        string fileName = enterUserName + ".txt";

        ifstream inFile(fileName);

        if(!inFile)
        {
            cout << "Error: user does not exist.\n";
            return;
        }

        string stored_UserName;
        string stored_Password;

        getline(inFile, stored_UserName);
        getline(inFile, stored_Password);

        inFile.close();

        if(enterUserName == stored_UserName &&
           enterPassword == stored_Password)
        {
            cout << "Login Successful!\n";
        }
        else
        {
            cout << "Invalid Password.\n";
        }
    }
};

int main()
{
    User user1;

    int choice;

    do
    {
        cout << "\n\t_____---- MENU ----_____\t\n";
        cout << "1. Register\n";
        cout << "2. Login\n";
        cout << "3. Exit\n";
        cout << "Enter Choice: ";
        cin >> choice;

        switch(choice)
        {
            case 1:
                user1.registerUser();
                break;

            case 2:
                user1.loginUser();
                break;

            case 3:
                cout << "Program Terminated.\n";
                break;

            default:
